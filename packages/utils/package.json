{
    "name": "@oda-components/utils",
    "version": "0.6.4",
    "description": "Internal utility runtime for ODA Components.",
    "keywords": [
        "oda-components",
        "utils",
        "ui-library"
    ],
    "license": "MIT",
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "default": "./dist/index.mjs"
        },
        "./*": {
            "types": "./dist/*/index.d.mts",
            "import": "./dist/*/index.mjs",
            "default": "./dist/*/index.mjs"
        }
    },
    "sideEffects": false,
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=12.11.0"
    }
}
