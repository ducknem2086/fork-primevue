{
    "name": "@oda-components/style-tokens",
    "version": "2.0.3",
    "description": "Internal component style tokens for ODA Components (re-exports @primeuix/styles).",
    "license": "MIT",
    "main": "../../../node_modules/@primeuix/styles/dist/index.mjs",
    "module": "../../../node_modules/@primeuix/styles/dist/index.mjs",
    "exports": {
        ".": {
            "import": "../../../node_modules/@primeuix/styles/dist/index.mjs",
            "default": "../../../node_modules/@primeuix/styles/dist/index.mjs"
        },
        "./*": {
            "import": "../../../node_modules/@primeuix/styles/dist/*/index.mjs",
            "default": "../../../node_modules/@primeuix/styles/dist/*/index.mjs"
        }
    },
    "sideEffects": false,
    "engines": {
        "node": ">=12.11.0"
    }
}
