{
    "name": "@app/oda-component",
    "private": false,
    "version": "4.5.14",
    "type": "module",
    "files": [
        "dist"
    ],
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json",
        "./dist/style.css": {
            "import": "./dist/style.css",
            "require": "./dist/style.css"
        },
        "./style-tokens/*": {
            "import": "./dist/style-tokens/*/index.js",
            "require": "./dist/style-tokens/*/index.cjs",
            "default": "./dist/style-tokens/*/index.js"
        },
        "./theme-tokens/*": {
            "types": "./dist/theme-tokens/*/index.d.ts",
            "import": "./dist/theme-tokens/*/index.js",
            "require": "./dist/theme-tokens/*/index.cjs",
            "default": "./dist/theme-tokens/*/index.js"
        },
        "./*": {
            "types": "./dist/*/index.d.ts",
            "import": "./dist/*/index.js",
            "require": "./dist/*/index.cjs",
            "default": "./dist/*/index.js"
        }
    },
    "sideEffects": [
        "*.css"
    ],
    "scripts": {
        "dev": "vite",
        "build": "node ./scripts/build.mjs",
        "build:version": "node ./scripts/build.mjs --set-version",
        "build:clean": "node ./scripts/build.mjs",
        "build:root": "pnpm run clean:dist && pnpm run build:prebuild && vite build && pnpm run build:types",
        "build:prebuild": "pnpm --dir ./src/packages/components exec cross-env NODE_ENV=production INPUT_DIR=src/ OUTPUT_DIR=dist/ node ./scripts/prebuild.mjs",
        "build:types": "node ./scripts/build-root-types.mjs",
        "build:app": "vite build",
        "clean": "node ./scripts/clean.mjs",
        "clean:all": "node ./scripts/clean.mjs --with-node-modules",
        "clean:dist": "node ./scripts/clean-root-dist.mjs",
        "clean:packages-dist": "node ./scripts/clean-packages-dist.mjs",
        "clean:packages-node-modules": "node ./scripts/clean-packages-node-modules.mjs",
        "preview": "vite preview",
        "build:metadata": "pnpm --filter @oda-components/metadata build",
        "build:resolver": "pnpm --filter @oda-components/auto-import-resolver build",
        "build:core": "pnpm --filter @oda-components/core build",
        "build:icons": "pnpm --filter @oda-components/icons build",
        "build:forms": "pnpm --filter @oda-components/forms build",
        "build:themes": "pnpm --filter @oda-components/themes build",
        "build:lib": "pnpm --filter ./src/packages/components build",
        "build:packages": "pnpm run build:metadata && pnpm run build:resolver && pnpm run build:core && pnpm run build:icons && pnpm run build:forms && pnpm run build:themes && pnpm run build:lib && pnpm run build:unified",
        "build:unified": "pnpm --filter ./src/packages/components build:unified",
        "build:bundle-dist": "node ./scripts/bundle-root-dist.mjs",
        "build:legacy": "pnpm run build:packages && pnpm run build:bundle-dist",
        "prepublish:component": "pnpm run clean:dist && pnpm --filter ./src/packages/components build",
        "publish:component": "pnpm run prepublish:component && pnpm --filter ./src/packages/components publish"
    },
    "dependencies": {
        "vue": "^3.5.34"
    },
    "peerDependencies": {
        "chart.js": "^4.0.0",
        "quill": "^1.3.7 || ^2.0.0",
        "vue": "^3.3.0"
    },
    "peerDependenciesMeta": {
        "chart.js": {
            "optional": true
        },
        "quill": {
            "optional": true
        }
    },
    "devDependencies": {
        "@babel/plugin-transform-runtime": "^7.26.10",
        "@babel/preset-env": "^7.21.5",
        "@primeuix/styled": "^0.7.4",
        "@primeuix/styles": "^2.0.3",
        "@primeuix/themes": "^2.0.3",
        "@primeuix/utils": "^0.6.4",
        "@rollup/plugin-alias": "^5.1.0",
        "@rollup/plugin-babel": "^6.0.3",
        "@rollup/plugin-node-resolve": "^15.2.3",
        "@rollup/plugin-terser": "^0.4.4",
        "@vitejs/plugin-vue": "^6.0.6",
        "cross-env": "^7.0.3",
        "fs-extra": "^11.3.0",
        "rimraf": "6.1.3",
        "rollup": "^4.30.1",
        "rollup-plugin-postcss": "^4.0.0",
        "rollup-plugin-vue": "^6.0.0-beta.9",
        "tsup": "^8.1.0",
        "typescript": "5.7.3",
        "vite": "^8.0.12"
    },
    "packageManager": "pnpm@9.6.0"
}
